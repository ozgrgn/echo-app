# ECHO panel environment variables.
# Copy to .env.local for local development (git-ignored).
# SvelteKit exposes PUBLIC_* vars to the browser (import.meta.env.PUBLIC_*).

# ECHO API base URL for the BROWSER (include /v1 prefix). PUBLIC_* is exposed client-side.
#
# LOCAL DEV — use the Vite dev proxy (vite.config.ts) to avoid CORS:
#   PUBLIC_ECHO_API_URL=/v1
#   Vite forwards /v1/* → the prod echo-api (server-to-server, no CORS)
#
# PRODUCTION (Railway env var) — point directly at echo-api:
#   PUBLIC_ECHO_API_URL=https://echo-api-production-b3a5.up.railway.app/v1
PUBLIC_ECHO_API_URL=https://echo-api-production-b3a5.up.railway.app/v1

# Operating mode: 'standalone' (Mode A) or 'hoops' (Mode B1 — embed).
# See spec §1.1. Phase 1 uses 'standalone'.
PUBLIC_ECHO_MODE=standalone

# ── SERVER-ONLY (SSR) ────────────────────────────────────────────────────────
# echo-api base URL for SERVER-side fetch. In production set this to the Railway
# private-network address so SSR loads never hit the public internet:
#   ECHO_API_INTERNAL_URL=http://echo-api.railway.internal:<PORT>/v1
# Leave UNSET in local dev (no internal DNS) — the server falls back to PUBLIC_ECHO_API_URL.
# ECHO_API_INTERNAL_URL=

# Secret used to encrypt the refresh cookie (AES-256-GCM). REQUIRED (dev + prod).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=change-me-32-byte-random-secret
