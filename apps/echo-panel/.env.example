# ECHO panel environment variables.
# Copy to .env.local for local development (git-ignored).
# SvelteKit exposes PUBLIC_* vars to the browser (import.meta.env.PUBLIC_*).

# ECHO API base URL (include /v1 prefix).
#
# LOCAL DEV — use the Vite dev proxy (vite.config.ts) to avoid CORS:
#   PUBLIC_ECHO_API_URL=/v1
#   Vite forwards /v1/* → https://backend-production-5c03.up.railway.app (server-to-server, no CORS)
#
# PRODUCTION (Railway env var) — point directly at the backend:
#   PUBLIC_ECHO_API_URL=https://backend-production-5c03.up.railway.app/v1
PUBLIC_ECHO_API_URL=https://backend-production-5c03.up.railway.app/v1

# Operating mode: 'standalone' (Mode A) or 'hoops' (Mode B1 — embed).
# See spec §1.1. Phase 1 uses 'standalone'.
PUBLIC_ECHO_MODE=standalone
