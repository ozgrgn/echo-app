{
  "name": "echo-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "ECHO hotel review intelligence frontend (panel + shared packages)",
  "scripts": {
    "dev": "pnpm --filter echo-panel dev",
    "dev:clean": "pnpm kill-port && pnpm dev",
    "kill-port": "lsof -ti :5173 2>/dev/null | xargs -r kill -9 2>/dev/null; echo 'port 5173 freed'",
    "build": "pnpm -r build",
    "start": "pnpm --filter echo-panel start",
    "lint": "pnpm -r lint",
    "check": "pnpm -r check"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.1.2"
}
