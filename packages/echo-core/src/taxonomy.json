        "FRONT"
      ]
    },
    {
      "pattern": "Yiyecek zehirlenmesi / mide",
      "category": "SECURITY",
      "subcategory": "food_safety",
      "excludeCategories": [
        "FOOD"
      ]
    },
    {
      "pattern": "Sigara içilmeyen alanda sigara / kuralı ihlal",
      "category": "SECURITY",
      "subcategory": "smoking_policy_violation",
      "excludeCategories": [
        "FACILITY",
        "ROOM"
      ],
      "rationale": "Smoking-policy violations are a safety/policy issue, not a facility complaint"
    },
    {
      "pattern": "Ekstra ücret / paid extra / charge / için ücret istendi",
      "category": "VALUE",
      "subcategory": "extra_charges",
      "excludeCategories": [
        "FOOD",
        "ROOM",
        "FACILITY",
        "SPA"
      ],
      "rationale": "When the main complaint is the charge itself, classify under VALUE/extra_charges. Do NOT create FOOD/ROOM/FACILITY/SPA aspects merely because the charged item belongs to those domains, unless the review separately evaluates the item quality."
    },
    {
      "pattern": "Her şey dahil yanıltıcı / dahil sanılan şey ücretli çıktı",
      "category": "VALUE",
      "subcategory": "concept_inclusion",
      "excludeCategories": [
        "FOOD",
        "ROOM"
      ],
      "rationale": "All-inclusive scope misrepresentation routes to VALUE/concept_inclusion"
    },
    {
      "pattern": "Fiyatına değmedi / pahalıydı (genel)",
      "category": "VALUE",
      "subcategory": "value_for_money",
      "excludeCategories": [],
      "rationale": "Generic price-vs-quality complaint with no specific item → VALUE/value_for_money"
    },
    {
      "pattern": "SPA satışı baskısı / fotoğraf baskısı / üyelik teklifi / sürekli ürün satışı",
      "category": "VALUE",
      "subcategory": "upselling_pressure",
      "excludeCategories": [
        "SPA",
        "STAFF"
      ],
      "rationale": "Sales pressure complaint about being constantly pitched extras routes to VALUE/upselling_pressure, not to the department being sold"
    },
    {
      "pattern": "Havuz kenarı cabana / pavilion / VIP gölgelik",
      "category": "POOL",
      "subcategory": "cabana_pavilion",
      "excludeCategories": [
        "BEACH",
        "FACILITY"
      ],
      "rationale": "Poolside premium shade structures route to POOL/cabana_pavilion"
    },
    {
      "pattern": "Plaj cabana / plajda pavilion / beach VIP",
      "category": "BEACH",
      "subcategory": "beach_cabana",
      "excludeCategories": [
        "POOL",
        "FACILITY"
      ],
      "rationale": "Beachside premium shade structures route to BEACH/beach_cabana"
    },
    {
      "pattern": "Resepsiyondaki personel yardımcı / staff at reception helpful / Personal an der Rezeption freundlich / персонал ресепшена",
      "category": "FRONT",
      "subcategory": "reception_service",
      "excludeCategories": [
        "STAFF"
      ],
      "rationale": "Reception-desk staff (any language) routes to FRONT/reception_service, NOT cross-cutting STAFF. Only unattributed/general staff praise goes to STAFF."
    },
    {
      "pattern": "Animatörler profesyonel / çocuklarla ilgili / animators great with children / Animateure professionell mit Kindern",
      "category": "KIDS",
      "subcategory": "kids_club",
      "excludeCategories": [
        "STAFF",
        "ENTERTAINMENT"
      ],
      "rationale": "Animator professionalism in a child-program context belongs to KIDS, NOT STAFF/professionalism or ENTERTAINMENT."
    },
    {
      "pattern": "Genel servis kalitesi / overall service quality (no food/restaurant context) / allgemeiner Service",
      "category": "STAFF",
      "subcategory": "friendliness_helpfulness",
      "excludeCategories": [
        "FOOD"
      ],
      "rationale": "Generic \"service quality\" with no dining context is overall staff service (STAFF), NOT FOOD/fb_service. fb_service requires explicit waiter/restaurant/table-service mention."
    },
    {
      "pattern": "Oda içi sorun hızlı çözüldü (kasa, klima, lamba) / room issue fixed quickly / Zimmerproblem schnell behoben",
      "category": "ROOM",
      "subcategory": "room_maintenance",
      "excludeCategories": [
        "FACILITY"
      ],
      "rationale": "In-room equipment fixes (safe, AC, lighting) route to ROOM/room_maintenance, NOT FACILITY/general_maintenance. FACILITY is for common-area/building-wide maintenance."
    },
    {
      "pattern": "SPA / masaj ücreti yüksek / spa treatment overpriced / Spa-Preise zu hoch",
      "category": "SPA",
      "subcategory": "spa_price_reservation",
      "excludeCategories": [
        "VALUE"
      ],
      "rationale": "A pricing complaint scoped to the SPA must use category=SPA with subcategory=spa_price_reservation (both fields SPA). Do NOT keep category=VALUE. VALUE/extra_charges is only for hotel-wide all-inclusive surcharge surprises with no specific department."
    }
  ]
