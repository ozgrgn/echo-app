  "disambiguationRules": [
    {
      "pattern": "Havlu gelmedi / oda havlusu",
      "category": "ROOM",
      "subcategory": "towel_linen",
      "excludeCategories": [
        "POOL",
        "STAFF"
      ],
      "rationale": "Room towel service is housekeeping, not pool"
    },
    {
      "pattern": "Havuz havlusu yoktu",
      "category": "POOL",
      "subcategory": "pool_towel",
      "excludeCategories": [
        "ROOM"
      ],
      "rationale": "Pool-area towel is pool department"
    },
    {
      "pattern": "Garson / servis yavaş / kaba",
      "category": "FOOD",
      "subcategory": "fb_service",
      "excludeCategories": [
        "STAFF"
      ],
      "rationale": "Waiter attitude is F&B service, not cross-cutting staff"
    },
    {
      "pattern": "Resepsiyoncu / front desk kaba",
      "category": "FRONT",
      "subcategory": "reception_service",
      "excludeCategories": [
        "STAFF"
      ],
      "rationale": "Reception desk behaviour routes to Front Office"
    },
    {
      "pattern": "Personel / herkes çok iyiydi",
      "category": "STAFF",
      "subcategory": "friendliness_helpfulness",
      "excludeCategories": [
        "FRONT",
        "FOOD",
        "ROOM"
      ],
      "rationale": "Unattributed staff praise → cross-cutting STAFF"
    },
    {
      "pattern": "Restoran / yemek alanı kirlik",
      "category": "FACILITY",
      "subcategory": "common_area_cleanliness",
      "excludeCategories": [
        "FOOD",
        "ROOM"
      ],
      "rationale": "Common dining area cleanliness is facility/housekeeping"
    },
    {
      "pattern": "Odada WiFi / internet yok",
      "category": "ROOM",
      "subcategory": "room_wifi_internet",
      "excludeCategories": [
        "FACILITY"
      ]
    },
    {
      "pattern": "Lobide / ortak alanda WiFi yok",
      "category": "FACILITY",
      "subcategory": "wifi_common_area",
      "excludeCategories": [
        "ROOM"
      ]
    },
    {
      "pattern": "Havuz kötüydü / pis",
      "category": "POOL",
      "subcategory": "pool_cleanliness",
      "excludeCategories": [
        "FACILITY"
      ]
    },
    {
      "pattern": "Havuz şezlongu yetersiz / Liegestühle am Pool",
      "category": "POOL",
      "subcategory": "sunbed_availability",
      "excludeCategories": [
        "BEACH"
      ],
      "rationale": "Sunbed availability at the pool belongs to POOL; beach sunbeds use sunbed_shade under BEACH"
    },
    {
      "pattern": "Plajda şezlong yeterli/yetersiz / beach sun loungers",
      "category": "BEACH",
      "subcategory": "sunbed_shade",
      "excludeCategories": [
        "POOL"
      ],
      "rationale": "Beach sunbed availability is captured by BEACH/sunbed_shade (covers both shade and number)"
    },
    {
      "pattern": "Animasyon / gece şov gürültüsü uyutmadı",
      "category": "ENTERTAINMENT",
      "subcategory": "entertainment_noise",
      "excludeCategories": [
        "ROOM"
      ],
      "rationale": "Noise source is entertainment; impact on sleep captured in evidence"
    },
    {
      "pattern": "Çocuk yemeği / bebek maması",
      "category": "FOOD",
      "subcategory": "diet_allergy_kids_food",
      "excludeCategories": [
        "KIDS"
      ],
      "rationale": "Child-specific food requests are handled by F&B; KIDS is for activities/club only"
    },
    {
      "pattern": "Mini klüp / kids club / kids disco / mini disco (sabit mekan + program)",
      "category": "KIDS",
      "subcategory": "kids_club",
      "excludeCategories": [
        "ENTERTAINMENT"
      ],
      "rationale": "Fixed-venue child program (mini club, kids disco) routes to KIDS/kids_club; ENTERTAINMENT is for general/adult animation"
    },
    {
      "pattern": "Animatörler çocuklarla ilgilendi / havuzda çocuk oyunu / sahil çocuk aktivitesi (mekandan bağımsız)",
      "category": "KIDS",
      "subcategory": "children_activities",
      "excludeCategories": [
        "ENTERTAINMENT",
        "STAFF"
      ],
      "rationale": "Venue-agnostic child activities belong to KIDS/children_activities, NOT entertainment_staff"
    },
    {
      "pattern": "Hırsızlık / eşya çalındı",
      "category": "SECURITY",
      "subcategory": "theft_lost_item",
      "excludeCategories": [
