{
  "compilerOptions": {
    "target":                          "ES2022",
    "module":                          "ESNext",
    "moduleResolution":                "Bundler",
    "lib":                             ["ES2022", "DOM"],
    "strict":                          true,
    "esModuleInterop":                 true,
    "skipLibCheck":                    true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":               true,
    "declaration":                     true,
    "noEmit":                          true,
    "isolatedModules":                 true,
    "verbatimModuleSyntax":            false,
    "paths": {
      "@talkwo/echo-core": ["../echo-core/src/index.ts"]
    }
  },
  "include": ["src/**/*", "evals/**/*"]
}
